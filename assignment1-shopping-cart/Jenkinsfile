pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS_ID = 'docker-hub-cred'
        DOCKERHUB_REPO = 'hechun202601/shopping-cart-localization'
        DOCKER_IMAGE_TAG = 'latest'
    }

    stages {
        stage('Build') {
            steps {
                dir('assignment1-shopping-cart') {
                    sh 'echo PATH=$PATH'
                    sh 'which mvn || true'
                    sh '/opt/homebrew/bin/mvn -v'
                    sh '/opt/homebrew/bin/mvn clean install -DskipTests'
                }
            }
        }

        stage('Test') {
            steps {
                dir('assignment1-shopping-cart') {
                    sh '/opt/homebrew/bin/mvn test'
                }
            }
        }

        stage('Code Coverage') {
            steps {
                dir('assignment1-shopping-cart') {
                    sh '/opt/homebrew/bin/mvn jacoco:report'
                }
            }
        }

        stage('Publish Test Results') {
            steps {
                junit '**/target/surefire-reports/*.xml'
            }
        }

        stage('Publish Coverage Report') {
            steps {
                recordCoverage(
                    tools: [[parser: 'JACOCO', pattern: 'assignment1-shopping-cart/target/site/jacoco/jacoco.xml']]
                )
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('assignment1-shopping-cart') {
                    sh '''
                        /usr/local/bin/docker --version
                        /usr/local/bin/docker build --platform linux/amd64 -t $DOCKERHUB_REPO:$DOCKER_IMAGE_TAG .
                    '''
                }
            }
        }

        stage('Push Docker Image to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: env.DOCKERHUB_CREDENTIALS_ID,
                    usernameVariable: 'DOCKERHUB_USERNAME',
                    passwordVariable: 'DOCKERHUB_PASSWORD'
                )]) {
                    dir('assignment1-shopping-cart') {
                        sh '''
                            echo "$DOCKERHUB_PASSWORD" | /usr/local/bin/docker login -u "$DOCKERHUB_USERNAME" --password-stdin
                            /usr/local/bin/docker push $DOCKERHUB_REPO:$DOCKER_IMAGE_TAG
                        '''
                    }
                }
            }
        }
    }
}