<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="rootPane"
            fitToWidth="true"
            fitToHeight="false"
            prefHeight="600.0"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hechun.shoppingcart.Controller">

    <content>
        <VBox fx:id="mainBox"
              spacing="10.0"
              maxWidth="Infinity"
              alignment="TOP_LEFT">
            <padding>
                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
            </padding>

            <children>
                <Label fx:id="selectLanguageLabel" maxWidth="Infinity" text="Select the language:" />

                <ComboBox fx:id="languageBox"
                          prefWidth="150.0"
                          promptText="English" />

                <Button fx:id="confirmLanguageButton"
                        maxWidth="Infinity"
                        mnemonicParsing="false"
                        onAction="#switchLanguage"
                        text="Confirm Language" />

                <Separator prefWidth="200.0" />

                <Label fx:id="enterItemsLabel" maxWidth="Infinity" text="Enter number of items:" />

                <TextField fx:id="numItemsField" promptText="Number of items" />

                <Button fx:id="enterItemsButton"
                        maxWidth="Infinity"
                        mnemonicParsing="false"
                        onAction="#handleItems"
                        text="Enter Items" />

                <VBox fx:id="itemsBox" spacing="8.0" maxWidth="Infinity" />

                <Button fx:id="calculateButton"
                        maxWidth="Infinity"
                        mnemonicParsing="false"
                        onAction="#handleCalculate"
                        text="Calculate Total" />

                <Label fx:id="resultLabel" maxWidth="Infinity" text="Total:" />
            </children>
        </VBox>
    </content>
</ScrollPane>